pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Checkout completed"
            }
        }
        
        stage('Install Node.js') {
            steps {
                sh '''
                    # Check if Node.js is already installed
                    if command -v node &> /dev/null; then
                        echo "Node.js is already installed:"
                        node -v
                        npm -v
                    else
                        # Add Homebrew to PATH
                        export PATH="/usr/local/bin:$PATH"
                        
                        # Install Node.js using Homebrew
                        echo "Installing Node.js using Homebrew..."
                        brew install node || echo "Failed to install Node.js with Homebrew"
                        
                        # Verify Node.js installation
                        /usr/local/bin/node -v || echo "Node.js installation failed"
                        /usr/local/bin/npm -v || echo "npm installation failed"
                    fi
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('OrangeHrm') {
                    sh '''
                        # Add Homebrew to PATH
                        export PATH="/usr/local/bin:$PATH"
                        
                        # Install dependencies
                        echo "Installing dependencies..."
                        npm install || /usr/local/bin/npm install || echo "npm install failed"
                    '''
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                dir('OrangeHrm') {
                    sh '''
                        # Add Homebrew to PATH
                        export PATH="/usr/local/bin:$PATH"
                        
                        # Create reports directory
                        mkdir -p reports
                        
                        # Run tests
                        echo "Running tests..."
                        npm run test || /usr/local/bin/npm run test || echo "Tests completed with issues"
                        
                        # List generated reports
                        echo "Generated reports:"
                        ls -la reports/
                    '''
                }
            }
        }
        
        stage('Archive Reports') {
            steps {
                dir('OrangeHrm') {
                    archiveArtifacts artifacts: 'reports/**', allowEmptyArchive: true
                }
            }
        }
    }
    
    post {
        always {
            echo "Pipeline completed"
        }
        success {
            echo "Tests passed successfully"
        }
        failure {
            echo "Tests failed"
        }
    }
}